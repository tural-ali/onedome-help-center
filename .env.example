# Copy to .env and fill in. .env is gitignored.
# Confluence service account (reads the CSKB space at build time).
ATLASSIAN_EMAIL=you@onedome.com
ATLASSIAN_API_TOKEN=

# Confluence source (defaults shown; override if needed).
CONFLUENCE_DOMAIN=onedome.atlassian.net
CSKB_SPACE_ID=591855635

# Cloudflare (only needed for local `wrangler pages deploy`; CI uses GH secrets).
# The token must have Account > Cloudflare Pages > Edit (+ User > User Details > Read).
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
